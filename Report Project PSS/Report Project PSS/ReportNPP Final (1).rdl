  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DevOrg">
      <ConnectionProperties>
        <DataProvider>MSCRMFETCH</DataProvider>
        <ConnectString>https://ssmgib-dev.crm5.dynamics.com/</ConnectString>
        <Prompt>Specify a user name and password for data source DevOrg:</Prompt>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>4fe1f5d7-a317-40b0-a93d-6e486cb0fd63</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsListBrokerageContracts">
      <Query>
        <DataSourceName>DevOrg</DataSourceName>
        <CommandText>&lt;fetch distinct="true"&gt;
  &lt;entity name="bsd_brokeragecontract"&gt;
    &lt;attribute name="bsd_brokeragecontractid" alias="brokeContID" /&gt;
    &lt;attribute name="bsd_name" alias="brokeContName" /&gt;
  &lt;/entity&gt;
&lt;/fetch&gt;</CommandText>
        <Timeout>300</Timeout>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="brokeContID">
          <DataField>brokeContID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="brokeContName">
          <DataField>brokeContName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsTamung">
      <Query>
        <DataSourceName>DevOrg</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@BrokerageContract">
            <Value>=Parameters!prBrokerageContract.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!prFromDate.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!prToDate.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>&lt;fetch&gt;
  &lt;entity name="bsd_repayment"&gt;
    &lt;attribute name="bsd_customer" alias="dsCustomer" /&gt;
    &lt;attribute name="bsd_depositdate" alias="dsDepositDate" /&gt;
    &lt;attribute name="bsd_signeddatebasecontract" alias="dsBaseContractSignDate" /&gt;
    &lt;attribute name="bsd_signeddatecontract" alias="dsContractSignDate" /&gt;
    &lt;attribute name="bsd_installment1paiddate" alias="dsInstallment1Date" /&gt;
    &lt;attribute name="bsd_datemoigioi" alias="dsNgayMoiGioi" /&gt;
    &lt;attribute name="bsd_comvalue" alias="dsCOMValue" /&gt;
    &lt;attribute name="bsd_distributor" alias="dsDistributor" /&gt;
    &lt;attribute name="bsd_settlementamount" alias="dsPMGGiulai" /&gt;
    &lt;attribute name="bsd_totalamount" alias="dsBrokerageFee" /&gt;
    &lt;attribute name="bsd_repaymentmoney" alias="dsRepaymentValue" /&gt;
    &lt;attribute name="bsd_additionvalue" alias="dsAdditonValue" /&gt;
    &lt;attribute name="bsd_units" alias="dsUnits" /&gt;
    &lt;attribute name="bsd_servicefee" alias="dsServiceFee" /&gt;
    &lt;attribute name="bsd_giftvalue" alias="dsGiftValue" /&gt;
    &lt;attribute name="bsd_project" alias="dsProject" /&gt;
    &lt;attribute name="bsd_contracts" alias="dsHDMB" /&gt;
    &lt;attribute name="bsd_quote" alias="dsHDCS" /&gt;
    &lt;attribute name="createdon" alias="dsCreateOn" /&gt;
    &lt;filter&gt;
      &lt;condition attribute="bsd_brokeragecontract" operator="eq" value="@BrokerageContract" /&gt;
      &lt;condition attribute="bsd_depositdate" operator="on-or-after" value="@FromDate" /&gt;
      &lt;condition attribute="bsd_depositdate" operator="on-or-before" value="@ToDate" /&gt;
      &lt;filter type="or"&gt;
        &lt;condition attribute="bsd_checkadditional" operator="eq" value="0" /&gt;
        &lt;condition attribute="bsd_checkadditional" operator="null" /&gt;
      &lt;/filter&gt;
    &lt;/filter&gt;
    &lt;order attribute="createdon" descending="true" /&gt;
    &lt;link-entity name="product" from="productid" to="bsd_units" link-type="outer"&gt;
      &lt;attribute name="bsd_areasqm" alias="areaThapTang" /&gt;
      &lt;attribute name="bsd_netsaleablearea" alias="areaCaoTang" /&gt;
      &lt;attribute name="bsd_numberofmonthspaidoperationmanagement" alias="monthPaideManagement" /&gt;
      &lt;attribute name="bsd_operationmanagementamount" alias="operationFee" /&gt;
      &lt;attribute name="bsd_typeunit" alias="typeUnit" /&gt;
      &lt;attribute name="bsd_landvalueofunit" alias="landvalueUnit" /&gt;
    &lt;/link-entity&gt;
    &lt;link-entity name="quote" from="quoteid" to="bsd_quote" link-type="outer"&gt;
      &lt;attribute name="bsd_totalamountdetails" alias="totalDetailHDCS" /&gt;
      &lt;attribute name="bsd_allotmentfee" alias="allotmentFeeHDCS" /&gt;
      &lt;attribute name="pricelevelid" alias="priceList" /&gt;
      &lt;attribute name="bsd_netsellingpriceland" alias="QSDDVAT" /&gt;
      &lt;attribute name="bsd_totalamountlessfreight" alias="netSellingPriceHDCS" /&gt;
      &lt;attribute name="bsd_totalamountland" alias="totalAmountLandHDCS" /&gt;
      &lt;attribute name="bsd_discount" alias="quoteDiscount" /&gt;
      &lt;attribute name="bsd_unittype" alias="loaiSPHDCS" /&gt;
    &lt;/link-entity&gt;
    &lt;link-entity name="salesorder" from="salesorderid" to="bsd_contracts" link-type="outer"&gt;
      &lt;attribute name="bsd_totalamountdetails" alias="totalDetailHDMB" /&gt;
      &lt;attribute name="bsd_allotmentfee" alias="allotmentFeeHDMB" /&gt;
      &lt;attribute name="bsd_discount" alias="oeDiscount" /&gt;
     &lt;attribute name="bsd_totalamountlessfreight" alias="netSellingPriceHDMB" /&gt;
     &lt;attribute name="bsd_totalamountland" alias="totalAmountLandHDMB" /&gt;
     &lt;attribute name="bsd_typeunit" alias="loaiSPHDMB" /&gt;
    &lt;/link-entity&gt;
    &lt;link-entity name="bsd_targetnpp" from="bsd_targetnppid" to="bsd_targetbrokeragefee" link-type="outer"&gt;
      &lt;attribute name="bsd_percen" alias="tarPercent" /&gt;
      &lt;attribute name="bsd_percentnow" alias="tarPercentOld" /&gt;
    &lt;/link-entity&gt;
    &lt;link-entity name="bsd_appendixcontractbrokerage" from="bsd_appendixcontractbrokerageid" to="bsd_appendixcontractbrokerage" link-type="outer"&gt;
      &lt;attribute name="bsd_brokeragefeesretain" alias="appenFeeRetain" /&gt;
      &lt;attribute name="bsd_brokeragefee" alias="appenNTT" /&gt;
    &lt;/link-entity&gt;
  &lt;/entity&gt;
&lt;/fetch&gt;</CommandText>
      </Query>
