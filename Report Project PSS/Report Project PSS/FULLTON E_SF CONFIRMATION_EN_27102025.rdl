          <Textbox Name="Textbox272">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Full Name</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Times New Roman</FontFamily>
                      <FontSize>12pt</FontSize>
                      <FontWeight>Bold</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>: </Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Times New Roman</FontFamily>
                      <FontSize>12pt</FontSize>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>=IIF(IsNothing(First(Fields!cont_name.Value, "dsCustomerInfo")) = True, IIF(IsNothing(First(Fields!cont_nameSys.Value, "dsCustomerInfo")) = True, "", UCase(First(Fields!cont_nameSys.Value, "dsCustomerInfo"))), UCase(First(Fields!cont_name.Value, "dsCustomerInfo")))</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Times New Roman</FontFamily>
                      <FontSize>12pt</FontSize>
                      <FontWeight>Bold</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <SpaceAfter>5pt</SpaceAfter>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Passport No: </Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Times New Roman</FontFamily>
                      <FontSize>12pt</FontSize>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>=IIF(IsNothing(First(Fields!cont_id.Value, "dsCustomerInfo")) = True, First(Fields!cont_passportNo.Value, "dsCustomerInfo"), First(Fields!cont_id.Value, "dsCustomerInfo"))</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Times New Roman</FontFamily>
                      <FontSize>12pt</FontSize>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
