    <DataSet Name="dsCustomerInfo">
      <Query>
        <DataSourceName>CRM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="CRM_salesorder">
            <Value>=Parameters!CRM_salesorder.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>&lt;fetch&gt;
  &lt;entity name="salesorder" enableprefiltering="1"&gt;
    &lt;link-entity name="account" from="accountid" to="customerid" link-type="outer" alias="account"&gt;
      &lt;attribute name="name" alias="acc_nameSys" /&gt;
      &lt;attribute name="bsd_name" alias="acc_name" /&gt;
      &lt;attribute name="bsd_accountnameother" alias="acc_nameEN" /&gt;
      &lt;attribute name="bsd_issuedon" alias="acc_RegIssuedon" /&gt;
      &lt;attribute name="bsd_placeofissue" alias="acc_RegPlaceofissue" /&gt;
      &lt;attribute name="bsd_descriptionregistration" alias="acc_RegDescription" /&gt;
      &lt;attribute name="bsd_rocnumber1" alias="acc_id" /&gt;
      &lt;attribute name="bsd_registrationcode" alias="acc_Regcode" /&gt;
      &lt;attribute name="fax" alias="acc_fax" /&gt;
      &lt;attribute name="accountnumber" alias="acc_number" /&gt;
      &lt;attribute name="telephone1" alias="acc_phone" /&gt;
      &lt;attribute name="emailaddress1" alias="acc_email" /&gt;
      &lt;attribute name="bsd_address" alias="acc_addVN" /&gt;
      &lt;attribute name="bsd_diachi" alias="acc_addEN" /&gt;
      &lt;attribute name="bsd_permanentaddress1" alias="acc_PerAddVN" /&gt;
      &lt;attribute name="bsd_diachithuongtru" alias="acc_PerAddEN" /&gt;
      &lt;attribute name="bsd_vatregistrationnumber" alias="acc_MaSoThue" /&gt;
      &lt;link-entity name="contact" from="contactid" to="primarycontactid" link-type="outer" alias="primary"&gt;
        &lt;attribute name="fullname" alias="primary_nameSys" /&gt;
        &lt;attribute name="bsd_fullname" alias="primary_name" /&gt;
        &lt;attribute name="jobtitle" alias="primary_job" /&gt;
        &lt;attribute name="bsd_jobtitlevn" alias="primary_jobVN" /&gt;
        &lt;attribute name="bsd_taxcode" alias="primary_MST" /&gt;
        &lt;attribute name="bsd_identitycardnumber" alias="primary_idnumber" /&gt;
        &lt;attribute name="bsd_placeofissue" alias="primary_placeissue" /&gt;
        &lt;attribute name="bsd_dategrant" alias="primary_dategrant" /&gt;
        &lt;attribute name="gendercode" alias="primary_gender" /&gt;
        &lt;attribute name="fax" alias="primary_fax" /&gt;
        &lt;attribute name="emailaddress1" alias="primary_email" /&gt;
        &lt;attribute name="mobilephone" alias="primary_phone" /&gt;
        &lt;attribute name="bsd_passport" alias="primary_passportNo" /&gt;
        &lt;attribute name="bsd_issuedonpassport" alias="primary_issuedon" /&gt;
        &lt;attribute name="bsd_placeofissuepassport" alias="primary_placeofissue" /&gt;
        &lt;attribute name="bsd_diachi" alias="primary_addEN" /&gt;
        &lt;attribute name="bsd_contactaddress" alias="primary_addVN" /&gt;
        &lt;attribute name="bsd_permanentaddress1" alias="Primary_PerAddVN" /&gt;
        &lt;attribute name="bsd_diachithuongtru" alias="Primary_PerAddEN" /&gt;
      &lt;/link-entity&gt;
      &lt;link-entity name="bsd_bankaccount" from="bsd_customer" to="accountid" link-type="outer" alias="AccBankAccount"&gt;
        &lt;attribute name="bsd_name" alias="primary_bankacc_number" /&gt;
        &lt;filter type="and"&gt;
          &lt;condition attribute="statecode" operator="eq" value="0" /&gt;
          &lt;condition attribute="bsd_default" operator="eq" value="1" /&gt;
        &lt;/filter&gt;
        &lt;link-entity name="bsd_bank" from="bsd_bankid" to="bsd_bank" link-type="outer" alias="AccBanks"&gt;
          &lt;attribute name="bsd_name" alias="primary_bankacc_nameVN" /&gt;
          &lt;attribute name="bsd_othername" alias="primary_bankacc_nameEN" /&gt;
          &lt;attribute name="bsd_address" alias="prybank_addVN" /&gt;
          &lt;attribute name="bsd_addressother" alias="prybank_addEN" /&gt;
        &lt;/link-entity&gt;
      &lt;/link-entity&gt;
    &lt;/link-entity&gt;
    &lt;link-entity name="contact" from="contactid" to="customerid" link-type="outer" alias="Cont"&gt;
      &lt;attribute name="gendercode" alias="cont_gender" /&gt;
      &lt;attribute name="fax" alias="cont_fax" /&gt;
      &lt;attribute name="fullname" alias="cont_nameSys" /&gt;
      &lt;attribute name="bsd_fullname" alias="cont_name" /&gt;
      &lt;attribute name="bsd_identitycardnumber" alias="cont_id" /&gt;
      &lt;attribute name="bsd_placeofissue" alias="cont_placeofissue" /&gt;
      &lt;attribute name="bsd_dategrant" alias="con_dategrant" /&gt;
      &lt;attribute name="jobtitle" alias="cont_job" /&gt;
      &lt;attribute name="emailaddress1" alias="cont_email" /&gt;
      &lt;attribute name="bsd_contactaddress" alias="cont_addVN" /&gt;
      &lt;attribute name="mobilephone" alias="cont_phone" /&gt;
      &lt;attribute name="bsd_passport" alias="cont_passportNo" /&gt;
      &lt;attribute name="bsd_issuedonpassport" alias="cont_passportissuedon" /&gt;
      &lt;attribute name="bsd_placeofissuepassport" alias="cont_passportplaceofissue" /&gt;
      &lt;attribute name="bsd_diachi" alias="cont_addEN" /&gt;
      &lt;attribute name="bsd_permanentaddress1" alias="cont_PerAddVN" /&gt;
      &lt;attribute name="bsd_diachithuongtru" alias="cont_PerAddEN" /&gt;
      &lt;attribute name="bsd_localization" alias="A2_location" /&gt;
      &lt;link-entity name="bsd_bankaccount" from="bsd_customer" to="contactid" link-type="outer" alias="ContBankAccount"&gt;
        &lt;attribute name="bsd_name" alias="contbankacc_number" /&gt;
        &lt;filter type="and"&gt;
          &lt;condition attribute="statecode" operator="eq" value="0" /&gt;
          &lt;condition attribute="bsd_default" operator="eq" value="1" /&gt;
        &lt;/filter&gt;
        &lt;link-entity name="bsd_bank" from="bsd_bankid" to="bsd_bank" link-type="outer" alias="ContBanks"&gt;
          &lt;attribute name="bsd_address" alias="contbank_add" /&gt;
          &lt;attribute name="bsd_addressother" alias="contbank_addEN" /&gt;
          &lt;attribute name="bsd_name" alias="contbank_name" /&gt;
          &lt;attribute name="bsd_othername" alias="contbank_nameEN" /&gt;
        &lt;/link-entity&gt;
      &lt;/link-entity&gt;
    &lt;/link-entity&gt;
    &lt;link-entity name="bsd_coowner" from="bsd_optionentry" to="salesorderid" link-type="outer" alias="cooner"&gt;
