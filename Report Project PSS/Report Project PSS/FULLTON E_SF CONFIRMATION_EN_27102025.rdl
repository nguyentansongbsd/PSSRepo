    <DataSet Name="dsArticle">
      <Query>
        <DataSourceName>CRM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="CRM_salesorder">
            <Value>=Parameters!CRM_salesorder.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>&lt;fetch&gt;
  &lt;entity name="salesorder" enableprefiltering="1"&gt;
    &lt;link-entity name="bsd_paymentschemedetail" from="bsd_optionentry" to="salesorderid" alias="psd"&gt;
      &lt;link-entity name="bsd_paymentscheme" from="bsd_paymentschemeid" to="bsd_paymentscheme" alias="ps"&gt;
        &lt;attribute name="bsd_terminationdate" alias="Total_liquidate" /&gt;
        &lt;attribute name="bsd_optionforfeiture" alias="ps_DepositForfeiture" /&gt;
        &lt;attribute name="bsd_spforfeiture" alias="ps_SPAForfeiture" /&gt;
        &lt;link-entity name="bsd_interestratemaster" from="bsd_interestratemasterid" to="bsd_interestratemaster" alias="interestrate"&gt;
          &lt;attribute name="bsd_toleranceinterestpercentage" alias="Total_percent_day" /&gt;
          &lt;attribute name="bsd_gracedays" alias="Grace_day" /&gt;
          &lt;attribute name="bsd_termsinterestpercentage" alias="Term_interest_Month" /&gt;
        &lt;/link-entity&gt;
      &lt;/link-entity&gt;
    &lt;/link-entity&gt;
  &lt;/entity&gt;
&lt;/fetch&gt;</CommandText>
      </Query>
      <Fields>
        <Field Name="Total_liquidate">
          <DataField>Total_liquidate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
