        &lt;attribute name="bsd_typeofroomvn" alias="TypeRoom_VN" /&gt;
        &lt;attribute name="bsd_typeofroomother" alias="TypeRoom_Other" /&gt;
        &lt;attribute name="bsd_itemvn" alias="Item_VN" /&gt;
        &lt;attribute name="bsd_itemother" alias="Item_Other" /&gt;
        &lt;attribute name="bsd_specificationsvn" alias="Specifications_VN" /&gt;
        &lt;attribute name="bsd_specificationsother" alias="Specifications_Other" /&gt;
        &lt;attribute name="bsd_brandsuppliervn" alias="Brandsupplier_VN" /&gt;
        &lt;attribute name="bsd_brandsupplierother" alias="Brandsupplier_Other" /&gt;
      &lt;/link-entity&gt;
      &lt;link-entity name="bsd_unittype" from="bsd_unittypeid" to="bsd_unittype" alias="unitype" &gt;
        &lt;attribute name="bsd_description" alias="Unit_DecsType" /&gt;
      &lt;/link-entity&gt;
      &lt;link-entity name="bsd_project" from="bsd_projectid" to="bsd_project" alias="proj" &gt;
