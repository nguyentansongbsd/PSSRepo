                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>Details of the scope of services included in the management fee for the Common Area of the Project and the regulations on the utilization of maintenance funds are specified in the Internal Regulations of the Housing Area in the Project.</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
