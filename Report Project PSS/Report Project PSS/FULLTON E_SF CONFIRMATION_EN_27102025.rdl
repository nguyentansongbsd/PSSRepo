        &lt;attribute name="jobtitle" alias="coo_cont_job" /&gt;
        &lt;attribute name="emailaddress1" alias="coo_cont_email" /&gt;
        &lt;attribute name="bsd_contactaddress" alias="coo_cont_addVN" /&gt;
        &lt;attribute name="mobilephone" alias="coo_cont_phone" /&gt;
        &lt;attribute name="bsd_passport" alias="coo_cont_passportNo" /&gt;
        &lt;attribute name="bsd_issuedonpassport" alias="coo_con_passportdategrant" /&gt;
