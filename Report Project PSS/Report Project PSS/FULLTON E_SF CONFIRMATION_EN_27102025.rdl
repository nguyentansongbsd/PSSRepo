                        <TablixCell>
                          <CellContents>
                            <Textbox Name="Textbox1170">
                              <CanGrow>true</CanGrow>
                              <KeepTogether>true</KeepTogether>
                              <Paragraphs>
                                <Paragraph>
                                  <TextRuns>
                                    <TextRun>
                                      <Value>=IIF(IsNothing(First(Fields!cont_id.Value, "dsCustomerInfo")) = True, First(Fields!cont_passportNo.Value, "dsCustomerInfo"), First(Fields!cont_id.Value, "dsCustomerInfo"))</Value>
                                      <Style>
                                        <FontStyle>Normal</FontStyle>
                                        <FontFamily>Times New Roman</FontFamily>
                                        <FontSize>12pt</FontSize>
                                        <FontWeight>Normal</FontWeight>
                                        <TextDecoration>None</TextDecoration>
                                        <Color>#000000</Color>
                                      </Style>
                                    </TextRun>
                                    <TextRun>
                                      <Value>, issued on: </Value>
                                      <Style>
                                        <FontStyle>Normal</FontStyle>
                                        <FontFamily>Times New Roman</FontFamily>
                                        <FontSize>12pt</FontSize>
                                        <FontWeight>Normal</FontWeight>
                                        <TextDecoration>None</TextDecoration>
                                        <Color>#000000</Color>
                                      </Style>
                                    </TextRun>
                                    <TextRun>
                                      <Value>=IIF(IsNothing(Fields!con_dategrant.Value) = True, 
IIF(IsNothing(Fields!cont_passportissuedon.Value) = True, "", 
Fields!cont_passportissuedon.Value), 
Fields!con_dategrant.Value)</Value>
                                      <Style>
                                        <FontStyle>Normal</FontStyle>
                                        <FontFamily>Times New Roman</FontFamily>
                                        <FontSize>12pt</FontSize>
                                        <FontWeight>Normal</FontWeight>
                                        <Format>dd/MM/yyyy</Format>
                                        <TextDecoration>None</TextDecoration>
                                        <Color>#000000</Color>
                                        <Language>vi-VN</Language>
                                        <NumeralLanguage>vi-VN</NumeralLanguage>
                                      </Style>
                                    </TextRun>
                                    <TextRun>
                                      <Value> by </Value>
                                      <Style>
                                        <FontStyle>Normal</FontStyle>
                                        <FontFamily>Times New Roman</FontFamily>
                                        <FontSize>12pt</FontSize>
                                        <FontWeight>Normal</FontWeight>
                                        <Format>dd/MM/yyyy</Format>
                                        <TextDecoration>None</TextDecoration>
                                        <Color>#000000</Color>
                                      </Style>
                                    </TextRun>
                                    <TextRun>
                                      <Value>=IIF(IsNothing(First(Fields!cont_placeofissue.Value, "dsCustomerInfo")) = True, First(Fields!cont_passportplaceofissue.Value, "dsCustomerInfo"), First(Fields!cont_placeofissue.Value, "dsCustomerInfo"))</Value>
