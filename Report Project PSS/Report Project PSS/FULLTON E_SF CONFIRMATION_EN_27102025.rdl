                    <TablixCell>
                      <CellContents>
                        <Textbox Name="Textbox247">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>For items in the Common Area of the Project that, the Developer must hand over to the State or other public service providers for management and operation according to regulations, the Buyer shall be responsible for contributing the management fee of the Common Area of the Project and maintenance funds in the period before such handover in accordance with the principles specified in this Letter and the Internal Regulations of the Housing Area in the Project. The Buyer agrees and undertakes that the Buyer has no objections to the circumstances that the rights and obligations of the Developer and the Management Company related to the Common Area of the Project are terminated after the Developer hands over the entire Common Area of the Project to the competent State agency (or a unit designated/authorized by the competent State agency) or partly terminated in correspondence with the part of the Common Area of the Project which is handed over to the competent State agency (or a unit designated/authorized by the competent State agency).</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontFamily>Times New Roman</FontFamily>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style />
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>Textbox247</rd:DefaultName>
                          <Style>
                            <Border>
                              <Style>None</Style>
                            </Border>
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                        <ColSpan>4</ColSpan>
                      </CellContents>
                    </TablixCell>
