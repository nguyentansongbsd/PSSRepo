      &lt;order attribute="bsd_ordernumber" /&gt;
    &lt;/link-entity&gt;
    &lt;link-entity name="product" from="productid" to="bsd_unitnumber" alias="product" &gt;
      &lt;attribute name="bsd_maintenancefeespercent" alias="maintenancefeespercent" /&gt;
