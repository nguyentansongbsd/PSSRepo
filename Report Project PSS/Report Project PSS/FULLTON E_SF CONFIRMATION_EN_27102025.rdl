        <DataSourceName>CRM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="CRM_salesorder">
            <Value>=Parameters!CRM_salesorder.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>&lt;fetch&gt;
  &lt;entity name="salesorder" enableprefiltering="1" &gt;
    &lt;attribute name="bsd_project" alias="Project" /&gt;
    &lt;link-entity name="bsd_unitsspecification" from="bsd_unitsspecificationid" to="bsd_unitsspecification" alias="us" &gt;
      &lt;attribute name="bsd_typeofunitspec" alias="TypeOfUnitSpec" /&gt;
      &lt;attribute name="bsd_descriptionvn" alias="typeNameVN" /&gt;
      &lt;attribute name="bsd_descriptionen" alias="typeNameEN" /&gt;
      &lt;link-entity name="bsd_unitsspecificationdetails" from="bsd_unitsspecification" to="bsd_unitsspecificationid" alias="usd" &gt;
        &lt;attribute name="bsd_typeno" alias="TypeNo" /&gt;
