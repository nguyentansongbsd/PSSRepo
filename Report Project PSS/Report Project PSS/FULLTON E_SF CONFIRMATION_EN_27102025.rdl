          </QueryParameter>
        </QueryParameters>
        <CommandText>&lt;fetch&gt;
  &lt;entity name="salesorder" enableprefiltering="1" &gt;
    &lt;attribute name="bsd_estimatehandoverdatecontract" alias="oe_estimateHOD" /&gt;
    &lt;link-entity name="bsd_paymentschemedetail" from="bsd_optionentry" to="salesorderid" link-type="inner" alias="inst" &gt;
      &lt;attribute name="bsd_duedate" alias="inst_estimateHOD" /&gt;
      &lt;filter type="and" &gt;
        &lt;condition attribute="bsd_duedatecalculatingmethod" operator="eq" value="100000002" /&gt;
        &lt;condition attribute="statecode" operator="eq" value="0" /&gt;
      &lt;/filter&gt;
    &lt;/link-entity&gt;
    &lt;link-entity name="product" from="productid" to="bsd_unitnumber" alias="units" &gt;
      &lt;attribute name="bsd_estimatehandoverdate" alias="units_estimateHOD" /&gt;
    &lt;/link-entity&gt;
  &lt;/entity&gt;
&lt;/fetch&gt;</CommandText>
