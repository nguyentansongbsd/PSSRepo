    <DataSet Name="dsBank">
      <Query>
        <DataSourceName>CRM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="CRM_salesorder">
            <Value>=Parameters!CRM_salesorder.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>&lt;fetch count="1" &gt;
  &lt;entity name="salesorder" enableprefiltering="1" &gt;
    &lt;attribute name="bsd_contractnumber" alias="SoHD" /&gt;
    &lt;link-entity name="bsd_project" from="bsd_projectid" to="bsd_project" alias="proj" &gt;
      &lt;attribute name="bsd_name" alias="proj_name" /&gt;
      &lt;attribute name="bsd_address" alias="proj_add" /&gt;
      &lt;attribute name="bsd_investor" alias="developer" /&gt;
      &lt;link-entity name="account" from="accountid" to="bsd_investor" alias="investor" &gt;
        &lt;attribute name="name" alias="investor_nameSys" /&gt;
        &lt;attribute name="bsd_name" alias="investor_name" /&gt;
        &lt;attribute name="bsd_accountnameother" alias="investor_nameEN" /&gt;
      &lt;/link-entity&gt;
      &lt;link-entity name="bsd_projectbankaccount" from="bsd_project" to="bsd_projectid" link-type="outer" alias="pba" &gt;
        &lt;attribute name="bsd_bank" alias="bank_name" /&gt;
        &lt;attribute name="bsd_name" alias="bankaccountnumber" /&gt;
        &lt;order attribute="createdon" descending="true" /&gt;
        &lt;filter type="and" &gt;
          &lt;condition attribute="bsd_default" operator="eq" value="1" /&gt;
        &lt;/filter&gt;
        &lt;link-entity name="bsd_bank" from="bsd_bankid" to="bsd_bank" link-type="outer" alias="bank" &gt;
          &lt;attribute name="bsd_othername" alias="bank_nameEN" /&gt;
		  &lt;attribute name="bsd_taxcode" alias="bank_taxcode" /&gt;
          &lt;attribute name="bsd_address" alias="bank_add" /&gt;
          &lt;attribute name="bsd_addressother" alias="bank_addEN" /&gt;
          &lt;attribute name="bsd_swiftcode" alias="bank_swiftcode" /&gt;
          &lt;attribute name="bsd_refcode" alias="bank_refcode" /&gt;
        &lt;/link-entity&gt;
      &lt;/link-entity&gt;
    &lt;/link-entity&gt;
    &lt;link-entity name="product" from="productid" to="bsd_unitnumber" link-type="outer" alias="product" &gt;
      &lt;attribute name="name" alias="CanHoSo" /&gt;
      &lt;link-entity name="bsd_applybankaccountunits" from="bsd_units" to="productid" link-type="outer" alias="abau" &gt;
        &lt;attribute name="bsd_accountno" alias="prod_accNo" /&gt;
        &lt;order attribute="createdon" descending="true" /&gt;
        &lt;link-entity name="bsd_applybankaccount" from="bsd_applybankaccountid" to="bsd_applybankaccount" link-type="outer" alias="ab" &gt;
          &lt;link-entity name="bsd_projectbankaccount" from="bsd_projectbankaccountid" to="bsd_projectbankaccount" link-type="outer" alias="ac" &gt;
            &lt;attribute name="bsd_bank" alias="prod_bank_name" /&gt;
            &lt;attribute name="bsd_name" alias="prod_bankaccountnumber" /&gt;
            &lt;link-entity name="bsd_bank" from="bsd_bankid" to="bsd_bank" link-type="outer" alias="prod_bank" &gt;
              &lt;attribute name="bsd_othername" alias="prod_bank_nameEN" /&gt;
			  &lt;attribute name="bsd_taxcode" alias="prod_bank_taxcode" /&gt;
              &lt;attribute name="bsd_address" alias="prod_bank_add" /&gt;
              &lt;attribute name="bsd_addressother" alias="prod_bank_addEN" /&gt;
              &lt;attribute name="bsd_swiftcode" alias="prod_bank_swiftcode" /&gt;
              &lt;attribute name="bsd_refcode" alias="prod_bank_refcode" /&gt;
            &lt;/link-entity&gt;
          &lt;/link-entity&gt;
        &lt;/link-entity&gt;
      &lt;/link-entity&gt;
    &lt;/link-entity&gt;
  &lt;/entity&gt;
&lt;/fetch&gt;</CommandText>
      </Query>
