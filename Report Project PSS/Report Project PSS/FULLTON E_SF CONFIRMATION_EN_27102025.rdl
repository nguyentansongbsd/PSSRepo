                                        <Color>#000000</Color>
                                      </Style>
                                    </TextRun>
                                    <TextRun>
                                      <Value>=IIF(IsNothing(Fields!primary_dategrant.Value) = True, 
IIF(IsNothing(Fields!primary_issuedon.Value) = True, "", 
Fields!primary_issuedon.Value), 
Fields!primary_dategrant.Value)</Value>
                                      <Style>
                                        <FontStyle>Normal</FontStyle>
                                        <FontFamily>Times New Roman</FontFamily>
