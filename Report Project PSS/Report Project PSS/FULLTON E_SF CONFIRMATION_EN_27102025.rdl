  <DataSets>
    <DataSet Name="dsContract">
      <Query>
        <DataSourceName>CRM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="CRM_salesorder">
            <Value>=Parameters!CRM_salesorder.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>&lt;fetch&gt;
  &lt;entity name="salesorder" enableprefiltering="1"&gt;
    &lt;attribute name="bsd_contractnumber" alias="ContractNumber" /&gt;
    &lt;attribute name="ordernumber" alias="orderNumber" /&gt;
    &lt;attribute name="bsd_optionno" alias="OE_OptionNo" /&gt;
    &lt;attribute name="createdon" alias="orderDate" /&gt;
    &lt;attribute name="bsd_contractdate" alias="ContractDate" /&gt;
    &lt;attribute name="bsd_contractprinteddate" alias="ContractPrintedDate" /&gt;
    &lt;attribute name="bsd_signedcontractdate" alias="SignedContractDate" /&gt;
    &lt;attribute name="totaltax" alias="ordertotaltax" /&gt;
    &lt;attribute name="bsd_detailamount" alias="order_pricebfdiscount" /&gt;
    &lt;attribute name="bsd_freightamount" alias="order_maintanencefee" /&gt;
    &lt;attribute name="name" alias="orderName" /&gt;
    &lt;attribute name="totalamount" alias="order_totalpriceofunit" /&gt;
    &lt;attribute name="bsd_totalamountlessfreight" alias="order_NetSellingPrice" /&gt;
&lt;attribute name="bsd_nameofauthorizedperson" alias="cont_name_oe" /&gt;
&lt;attribute name="bsd_idofauthorizedperson" alias="cont_ID_oe" /&gt;
&lt;attribute name="bsd_issuedon" alias="cont_issuedon_oe" /&gt;
&lt;attribute name="bsd_issuedby" alias="cont_issuedby_oe" /&gt;
&lt;attribute name="bsd_authorizationcode" alias="cont_author_oe" /&gt;
&lt;attribute name="bsd_dateofauthorization" alias="cont_author_date_oe" /&gt;
&lt;attribute name="bsd_notarizedbyanotaryoffice" alias="cont_author_by_oe" /&gt;
&lt;attribute name="bsd_paymentscheme" alias="A_payment_scheme" /&gt;
    &lt;link-entity name="bsd_project" from="bsd_projectid" to="bsd_project" alias="proj"&gt;
      &lt;attribute name="bsd_name" alias="proj_name" /&gt;
      &lt;attribute name="bsd_address" alias="proj_add" /&gt;
      &lt;attribute name="bsd_addressen" alias="proj_adden" /&gt;
      &lt;link-entity name="account" from="accountid" to="bsd_investor" alias="investor"&gt;
        &lt;attribute name="bsd_mandatorysecondary" alias="MandatorySecondary" /&gt;
        &lt;attribute name="name" alias="investor_nameSys" /&gt;
        &lt;attribute name="bsd_name" alias="investor_name" /&gt;
        &lt;attribute name="bsd_accountnameother" alias="investor_nameEN" /&gt;
        &lt;attribute name="bsd_companycode" alias="investor_companycode" /&gt;
        &lt;attribute name="bsd_address" alias="investor_addvn_lh" /&gt;
        &lt;attribute name="bsd_diachi" alias="investor_adden_lh" /&gt;
        &lt;attribute name="bsd_permanentaddress1" alias="investor_addvn_tt" /&gt;
        &lt;attribute name="bsd_diachithuongtru" alias="investor_adden_tt" /&gt;
        &lt;attribute name="emailaddress1" alias="investor_email" /&gt;
        &lt;attribute name="fax" alias="investor_fax" /&gt;
        &lt;attribute name="telephone1" alias="investor_phone" /&gt;
        &lt;attribute name="bsd_vatregistrationnumber" alias="investor_VATcode" /&gt;
        &lt;attribute name="bsd_registrationcode" alias="investor_Regcode" /&gt;
        &lt;attribute name="bsd_issuedon" alias="investor_RegIssuedon" /&gt;
        &lt;attribute name="bsd_placeofissue" alias="investor_RegPlaceofissue" /&gt;
        &lt;link-entity name="contact" from="contactid" to="primarycontactid" link-type="outer" alias="cont_primarycontact"&gt;
          &lt;attribute name="fullname" alias="primary_nameSys" /&gt;
          &lt;attribute name="bsd_fullname" alias="primary_name" /&gt;
          &lt;attribute name="jobtitle" alias="primary_jobEN" /&gt;
          &lt;attribute name="bsd_jobtitlevn" alias="primary_jobVN" /&gt;
          &lt;attribute name="bsd_identitycardnumber" alias="primary_idnumber" /&gt;
          &lt;attribute name="bsd_placeofissue" alias="primary_placeissue" /&gt;
          &lt;attribute name="bsd_dategrant" alias="primary_dategrant" /&gt;
          &lt;attribute name="bsd_diachi" alias="primary_addEN" /&gt;
          &lt;attribute name="bsd_contactaddress" alias="primary_addVN" /&gt;
          &lt;attribute name="bsd_permanentaddress1" alias="primary_PerAddVN" /&gt;
          &lt;attribute name="bsd_diachithuongtru" alias="Primary_PerAddEN" /&gt;
        &lt;/link-entity&gt;
        &lt;link-entity name="bsd_mandatorysecondary" from="bsd_developeraccount" to="accountid" link-type="outer" alias="mansecond"&gt;
          &lt;attribute name="bsd_name" alias="mandasecond_Topic" /&gt;
          &lt;attribute name="bsd_developeraccount" alias="mandasecond_DeveloperAccount" /&gt;
          &lt;attribute name="bsd_contact" alias="mandasecond_Contact" /&gt;
          &lt;attribute name="bsd_jobtitlevn" alias="mandasecond_JobTitleVN" /&gt;
          &lt;attribute name="bsd_jobtitleen" alias="mandasecond_JobTitleEN" /&gt;
          &lt;attribute name="bsd_descriptionsvn" alias="mandasecond_DescriptionsVN" /&gt;
          &lt;attribute name="bsd_descriptionsen" alias="mandasecond_DescriptionsEN" /&gt;
          &lt;filter type="and"&gt;
            &lt;condition attribute="statuscode" operator="eq" value="100000000" /&gt;
          &lt;/filter&gt;
          &lt;link-entity name="contact" from="contactid" to="bsd_contact" link-type="outer" alias="mansecond_contact"&gt;
            &lt;attribute name="fullname" alias="mandasecond_nameSys" /&gt;
            &lt;attribute name="bsd_fullname" alias="mandasecond_name" /&gt;
            &lt;attribute name="jobtitle" alias="mandasecond_jobEN" /&gt;
            &lt;attribute name="bsd_jobtitlevn" alias="mandasecond_jobVN" /&gt;
            &lt;attribute name="bsd_diachi" alias="mandasecond_addEN" /&gt;
            &lt;attribute name="bsd_contactaddress" alias="mandasecond_addVN" /&gt;
            &lt;attribute name="bsd_permanentaddress1" alias="mandasecond_PerAddVN" /&gt;
            &lt;attribute name="bsd_diachithuongtru" alias="mandasecond_PerAddEN" /&gt;
            &lt;attribute name="bsd_identitycardnumber" alias="mandasecond_idnumber" /&gt;
            &lt;attribute name="bsd_placeofissue" alias="mandasecond_placeissue" /&gt;
            &lt;attribute name="bsd_dategrant" alias="mandasecond_dategrant" /&gt;
            &lt;attribute name="bsd_passport" alias="mandasecond_passportNo" /&gt;
            &lt;attribute name="bsd_issuedonpassport" alias="mandasecond_passportIssuedon" /&gt;
            &lt;attribute name="bsd_placeofissuepassport" alias="mandasecond_passportPlaceofissue" /&gt;
          &lt;/link-entity&gt;
        &lt;/link-entity&gt;
      &lt;/link-entity&gt;
    &lt;/link-entity&gt;
  &lt;/entity&gt;
&lt;/fetch&gt;</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
