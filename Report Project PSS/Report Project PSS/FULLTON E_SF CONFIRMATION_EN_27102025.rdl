&lt;link-entity name="bsd_unittype" from="bsd_unittypeid" to="bsd_unittype" alias="unittype"&gt;
      &lt;attribute name="bsd_unittypeid" alias="unittypeid" /&gt;
      &lt;attribute name="bsd_name" alias="unittype_code" /&gt;
    &lt;/link-entity&gt;
      &lt;/link-entity&gt;
    &lt;/link-entity&gt;
  &lt;/entity&gt;
&lt;/fetch&gt;</CommandText>
      </Query>
