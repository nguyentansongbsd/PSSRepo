    <DataSet Name="dsPSDetail">
      <Query>
        <DataSourceName>CRM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="CRM_salesorder">
            <Value>=Parameters!CRM_salesorder.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>&lt;fetch&gt;
  &lt;entity name="salesorder" enableprefiltering="1" &gt;
    &lt;attribute name="bsd_numberofmonthspaidmf" alias="NumberMonth" /&gt;
    &lt;attribute name="bsd_freightamount" alias="order_maintanancefee" /&gt;
    &lt;attribute name="bsd_managementfee" alias="order_managementfee" /&gt;
    &lt;link-entity name="bsd_paymentschemedetail" from="bsd_optionentry" to="salesorderid" alias="ps" &gt;
      &lt;attribute name="bsd_name" alias="psName" /&gt;
      &lt;attribute name="bsd_txamountofphasevn" alias="ReadAmountofPhase_VN" /&gt;
      &lt;attribute name="bsd_txamountofphaseen" alias="ReadAmountofPhase_EN" /&gt;
      &lt;attribute name="bsd_duedate" alias="psduedate" /&gt;
      &lt;attribute name="bsd_ordernumber" alias="psordernumber" /&gt;
      &lt;attribute name="bsd_lastinstallment" alias="psLastInstallment" /&gt;
      &lt;attribute name="bsd_amountofthisphase" alias="psamount" /&gt;
      &lt;attribute name="bsd_duedatecalculatingmethod" alias="duedatecalculatingmethod" /&gt;
      &lt;attribute name="bsd_temporaryhandover" alias="inst_TemporaryHandover" /&gt;
      &lt;filter type="and" &gt;
        &lt;condition attribute="bsd_lastinstallment" operator="neq" value="1" /&gt;
