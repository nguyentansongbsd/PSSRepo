                      <CellContents>
                        <Textbox Name="Textbox262">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>In case the State agency agrees to allow the Developer to continue managing and operating the above-mentioned works, areas and utilities for the Project, the Buyer is responsible for continuing pay their contributions of the management fee for the Common Area of the Project and maintenance funds to maintain the landscape and utilities according to the general standards of the Project as provided in this Letter.</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontFamily>Times New Roman</FontFamily>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
